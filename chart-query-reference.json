  "universal_query_pattern": {
    "structure": "SELECT [labelKey], [valueKey1], [valueKey2], ... FROM [table] GROUP BY [labelKey] ORDER BY [column]",
    "requirements": {
      "label_column": {
        "purpose": "X-axis labels or pie segments",
        "data_types": ["VARCHAR", "DATE", "DATETIME", "INT"],
        "rules": "Should contain categorical or temporal data"
      },
      "value_columns": {
        "purpose": "Y-axis values or segment sizes",
        "data_types": ["INT", "DECIMAL", "FLOAT", "BIGINT"],
        "rules": "Must be numeric, typically aggregated with SUM/COUNT/AVG"
      }
    }
  },
  "configuration_example": {
    "widget_setup": {
      "type": "bar",
      "title": "Monthly Revenue",
      "queryId": "monthly_sales_trend",
      "mapping": {
        "labelKey": "month",
        "valueKeys": ["revenue", "orderCount"],
        "color": "#9333ea",
        "palette": ["#9333ea", "#a855f7", "#c084fc", "#d8b4fe"]
      }
    }
  },
  "best_practices": {
    "line_charts": {
      "do": [
        "Use temporal/time-based labels (dates, months, quarters)",
        "Keep 1-3 value series for clarity",
        "Sort by time ascending",
        "Format dates consistently"
      ],
      "dont": [
        "Mix categorical and temporal data",
        "Include too many series (>5)",
        "Use for part-to-whole relationships",
        "Have irregular time intervals"
      ]
    },
    "bar_charts": {
      "do": [
        "Use categorical labels",
        "Include 1-3 value columns",
        "Sort by highest/lowest value",
        "Label axes clearly"
      ],
      "dont": [
        "Use temporal data as primary purpose",
        "Overcrowd with too many categories (>15)",
        "Mix incompatible units",
        "Forget units (%, $, count)"
      ]
    },
    "pie_charts": {
      "do": [
        "Use 1 value column (represents segments)",
        "Limit to 3-8 segments maximum",
        "Sum values to meaningful total (100%, revenue, etc.)",
        "Sort by value descending"
      ],
      "dont": [
        "Use multiple value columns",
        "Include too many small segments",
        "Use for time-series data",
        "Include negative values"
      ]
    }
  },
  "column_naming_conventions": {
    "recommended_labels": [
      "date", "month", "quarter", "year", "day",
      "country", "city", "region", "category", "status",
      "name", "type", "level", "segment", "product_line"
    ],
    "recommended_values": [
      "revenue", "amount", "total", "count", "quantity",
      "sales", "orders", "profit", "margin", "percentage",
      "rate", "average", "sum", "value", "metric"
    ]
  },
  "error_handling": {
    "common_issues": [
      {
        "issue": "Query returns NULL values",
        "solution": "Add WHERE column IS NOT NULL or use COALESCE(column, 'Unknown')"
      },
      {
        "issue": "Label column is numeric",
        "solution": "Use CASE/WHEN or CONCAT to convert to text, or use DATE_FORMAT for dates"
      },
      {
        "issue": "Chart renders but appears empty",
        "solution": "Verify labelKey and valueKeys match column aliases exactly (case-sensitive)"
      },
      {
        "issue": "Too many labels/segments",
        "solution": "Add LIMIT or use TOP N with UNION for 'Others' category"
      },
      {
        "issue": "Data looks incorrect",
        "solution": "Verify GROUP BY clauses, check for duplicate keys, validate aggregation functions"
      }
    ]
  }
}
