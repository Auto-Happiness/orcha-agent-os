# 🌌 ORCHA AGENT OS - Master Environment Template
# Use this as the source for Dockploy or local production setup.

# ─── CONVEX ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=
CONVEX_SELF_HOSTED_URL=http://localhost:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=
CONVEX_INTERNAL_SECRET=

# ─── CLERK (Auth) ──────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_ISSUER_DOMAIN=
CLERK_WEBHOOK_SECRET=

# ─── AI PROVIDERS ─────────────────────────────────────────────────────
# Used for the Semantic Bridge and Chat Agents
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=

# ─── GOOGLE (OAuth Tools) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SYSTEM & BRIDGE ──────────────────────────────────────────────────
# 32-character hex string required for credential decryption
ENCRYPTION_KEY=
KEY_STORAGE=convex
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── WORKERS (BullMQ) ──────────────────────────────────────────────────
# Set to 'on' to enable background processing for agents
ASYNC=on
REDIS_URL=redis://localhost:6379

# ─── DATA SOURCES (Optional) ──────────────────────────────────────────
# These can be used as system-wide defaults
# DATABASE_URL=
# MYSQL_URL=
# POSTGRES_URL=